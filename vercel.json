{
  "crons": [
    {
      "path": "/api/cron/sync-stock",
      "schedule": "0 16 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/health",
      "destination": "/api/portfolio"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}